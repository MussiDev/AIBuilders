# Copiar a apps/api/.env y completar con credenciales reales.
DATABASE_URL="postgresql://usuario:password@localhost:5432/finanzas?schema=public"
PORT=3001
# Secreto para firmar los JWT de sesión (RNF-04). Usar un valor largo y aleatorio en producción.
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"
